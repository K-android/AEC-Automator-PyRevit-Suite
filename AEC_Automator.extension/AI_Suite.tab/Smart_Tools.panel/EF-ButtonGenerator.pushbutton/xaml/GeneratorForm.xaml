<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="pyRevit Buttons Generator"
        Width="940" Height="660"
        MinWidth="720" MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="White"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">


    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="8"
                            CaptionHeight="0"
                            GlassFrameThickness="0,0,0,1"
                            CornerRadius="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ============================================================ -->
        <!--  COLORS                                                      -->
        <!-- ============================================================ -->
        <SolidColorBrush x:Key="AccentBrush"                 Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentHoverBrush"            Color="#2563EB"/>
        <SolidColorBrush x:Key="ContainerSelectedBrush"      Color="#F87171"/>
        <SolidColorBrush x:Key="ContainerSelectedHoverBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="RemoveBrush"                 Color="#EF4444"/>
        <SolidColorBrush x:Key="RemoveSoftBgBrush"           Color="#FEE2E2"/>
        <SolidColorBrush x:Key="HairlineBrush"               Color="#E5E7EB"/>
        <SolidColorBrush x:Key="HairlineHoverBrush"          Color="#D1D5DB"/>
        <SolidColorBrush x:Key="WindowBorderBrush"           Color="#B7BFC9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"            Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"          Color="#6B7280"/>
        <SolidColorBrush x:Key="TextMutedBrush"              Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BadgeBgBrush"                Color="#F3F4F6"/>
        <SolidColorBrush x:Key="BadgeHoverBgBrush"           Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BadgeBorderBrush"            Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BadgeTextBrush"              Color="#374151"/>
        <SolidColorBrush x:Key="ChipBgBrush"                 Color="#EFF6FF"/>
        <SolidColorBrush x:Key="ChipBorderBrush"             Color="#BFDBFE"/>
        <SolidColorBrush x:Key="ChipTextBrush"               Color="#1E3A8A"/>

        <!-- ============================================================ -->
        <!--  DEFAULT STYLES                                              -->
        <!-- ============================================================ -->
        <Style TargetType="TextBox">
            <Setter Property="Padding"                  Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{StaticResource HairlineBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="FontSize"                 Value="13"/>
        </Style>

        <Style x:Key="FlatButtonBase" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="20,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding"    Value="14,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BadgeHoverBgBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  Title-bar close button                                      -->
        <!-- ============================================================ -->
        <Style x:Key="TitleCloseStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Content"    Value="&#x2715;"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Width"      Value="36"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="ToolTip"    Value="Close"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RemoveSoftBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource RemoveBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  Badges (rounded rectangles, smaller font)                   -->
        <!-- ============================================================ -->
        <Style x:Key="BadgeUnselected" TargetType="Border">
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="7,4,7,4"/>
            <Setter Property="Margin"          Value="0,0,5,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="{StaticResource BadgeBgBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BadgeBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource BadgeHoverBgBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource HairlineHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeSelectedSingle" TargetType="Border" BasedOn="{StaticResource BadgeUnselected}">
            <Setter Property="Background"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource AccentHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeSelectedContainer" TargetType="Border" BasedOn="{StaticResource BadgeUnselected}">
            <Setter Property="Background"  Value="{StaticResource ContainerSelectedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ContainerSelectedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource ContainerSelectedHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource ContainerSelectedHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeTextUnselected" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BadgeTextBrush}"/>
        </Style>
        <Style x:Key="BadgeTextSelected" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextUnselected}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ============================================================ -->
        <!--  Chips (rounded rectangles)                                  -->
        <!-- ============================================================ -->
        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Background"      Value="{StaticResource ChipBgBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource ChipBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,2,4,2"/>
            <Setter Property="Margin"          Value="0,3,4,3"/>
        </Style>

        <Style x:Key="ChipTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{StaticResource ChipTextBrush}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Margin"            Value="0,0,4,0"/>
        </Style>

        <Style x:Key="ChipRemoveStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Content"    Value="&#x2715;"/>
            <Setter Property="Foreground" Value="{StaticResource RemoveBrush}"/>
            <Setter Property="Padding"    Value="4,0,4,0"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <Style x:Key="ChipInputStyle" TargetType="TextBox">
            <Setter Property="MinWidth"                 Value="110"/>
            <Setter Property="Margin"                   Value="0,3,0,3"/>
            <Setter Property="Padding"                  Value="6,4"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="BorderBrush"              Value="{StaticResource HairlineBrush}"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>

        <!-- ============================================================ -->
        <!--  URL prefix badge                                            -->
        <!-- ============================================================ -->
        <Style x:Key="UrlBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius"      Value="6"/>
            <Setter Property="Background"        Value="{StaticResource ChipBgBrush}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource ChipBorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="10,3,10,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ============================================================ -->
        <!--  Row remove                                                  -->
        <!-- ============================================================ -->
        <Style x:Key="RowRemoveStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Content"           Value="&#x2715;"/>
            <Setter Property="Foreground"        Value="{StaticResource RemoveBrush}"/>
            <Setter Property="FontSize"          Value="16"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="Padding"           Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip"           Value="Remove this row"/>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="2,0"/>
        </Style>

    </Window.Resources>


    
    
    <Border Background="White"
            BorderBrush="{StaticResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============== Title bar (icon + title + close) ============== -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,0,1">
                <Grid x:Name="titleBar" Background="Transparent" Height="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           x:Name="img_TitleIcon"
                           Width="26" Height="26"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="pyRevit Buttons Generator"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <Button Grid.Column="2"
                            x:Name="btn_Close"
                            Style="{StaticResource TitleCloseStyle}"
                            Margin="0,0,8,0"/>
                </Grid>
            </Border>

            <!-- ============== Content ============== -->
            <Grid Grid.Row="1" Margin="20,4,20,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Subheading + Target panel selector -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Create new pyRevit Buttons, Stacks and Pulldown menus with a quick UI interface."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               FontSize="12"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <TextBlock Text="Target panel:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,6,0"/>
                        <ComboBox x:Name="cb_Panel"
                                  MinWidth="160"
                                  FontSize="12"
                                  Padding="6,2"/>
                    </StackPanel>
                </Grid>

                <!-- Column headers -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="290"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="NAME"               Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Grid.Column="1" Text="TYPE"               Style="{StaticResource ColumnHeaderStyle}"/>
                    <TextBlock Grid.Column="2" Text="NESTED PUSHBUTTONS" Style="{StaticResource ColumnHeaderStyle}"/>
                </Grid>

                <!-- Rows -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="sp_Rows"/>
                    </ScrollViewer>
                </Border>

                <!-- Footer buttons -->
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btn_AddRow"
                                Content="+ Add Row"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <TextBlock Text="or press Ctrl+Enter to add a row"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- Inline status for form-level issues (replaces pop-ups) -->
                    <TextBlock Grid.Column="1"
                               x:Name="tb_GlobalError"
                               Foreground="{StaticResource RemoveBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               TextWrapping="Wrap"
                               Margin="16,0,12,0"
                               Visibility="Collapsed"/>

                    <Button Grid.Column="2"
                            x:Name="btn_Cancel"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Grid.Column="3"
                            x:Name="btn_Create"
                            Content="Create"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </Grid>

                <!-- Credit footer: only "LearnRevitAPI.com" is the hyperlink -->
                <TextBlock Grid.Row="4"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="Made by Erik Frits from "/><Hyperlink x:Name="link_Author"
                                                                     NavigateUri="https://LearnRevitAPI.com/?utm_source=starter-kit&amp;utm_medium=pyrevit-button&amp;utm_campaign=button-generator"
                                                                     Foreground="{StaticResource TextSecondaryBrush}"
                                                                     TextDecorations="Underline">LearnRevitAPI.com</Hyperlink>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
